# SkinCure storefront — environment variables
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# Base URL of the SkinCure backend API. All /api/v1/* requests are made against it.
# Example: http://localhost:5000
NEXT_PUBLIC_SERVER_URL=

# Stripe PUBLISHABLE key (safe to expose to the browser). Use a test key in development.
# Example: pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PK=

# Sanity CMS (optional — currently scaffolded but unused by the app).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
